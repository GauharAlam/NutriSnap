{
  "name": "fitness-nutrition-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev --workspace client",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "dev:all": "sh -c 'npm run dev:server & npm run dev:client & wait'",
    "build": "npm run build --workspace client",
    "build:client": "npm run build --workspace client",
    "test": "npm run test --workspace server",
    "lint": "npm run lint --workspace client",
    "verify": "npm run lint && npm run test && npm run build:client"
  }
}
