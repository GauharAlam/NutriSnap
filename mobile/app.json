{
  "expo": {
    "name": "NutriSnap",
    "slug": "nutrisnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nutrisnap",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#08080f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nutrisnap.app",
      "infoPlist": {
        "NSCameraUsageDescription": "NutriSnap needs camera access to scan your food for AI nutrition analysis.",
        "NSPhotoLibraryUsageDescription": "NutriSnap needs photo library access to select food photos for nutrition analysis."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#08080f"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nutrisnap.app",
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "cameraPermission": "NutriSnap needs camera access to scan your food for AI nutrition analysis.",
          "photosPermission": "NutriSnap needs photo library access to select food photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
