# Server Configuration
CLIENT_URL=http://localhost:5173
PORT=5001
SERVER_URL=http://localhost:5001

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/NutriSnap?retryWrites=true&w=majority

# Auth — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_strong_random_secret

# AI — choose one provider
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Or use OpenAI instead
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o

# Environment
NODE_ENV=development
